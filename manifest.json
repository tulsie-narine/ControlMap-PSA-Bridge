{
  "manifest_version": 3,
  "name": "ControlMap Bridge",
  "version": "0.4.0",
  "description": "Context-aware overlay for ControlMap: PSA ticketing (Autotask, ConnectWise, HaloPSA) plus an open integration framework that pulls compliance evidence from security tools (SentinelOne first) and proposes assessment answers.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.app.ctrlmap.com/*",
    "https://api.scalepad.com/*",
    "https://eu.api.scalepad.com/*",
    "https://ca.api.scalepad.com/*",
    "https://au.api.scalepad.com/*",
    "https://*.autotask.net/*",
    "https://*.myconnectwise.net/*",
    "https://*.halopsa.com/*",
    "https://*.haloitsm.com/*",
    "https://*.sentinelone.net/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "strip_origin",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.app.ctrlmap.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "ControlMap Bridge \u2014 open settings"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "integrations/*/logo.svg"
      ],
      "matches": [
        "https://*.app.ctrlmap.com/*"
      ]
    }
  ]
}